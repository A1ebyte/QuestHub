name: Update README Date

on:
  schedule:
    - cron: "0 0 * * *"   # Cada día a las 00:00 UTC
  workflow_dispatch:

jobs:
  update-readme:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repo
        uses: actions/checkout@v3
        with:
          token: ${{ secrets.PAT_ADMIN }}   # Tu token de admin

      - name: Update date in README
        run: |
          DATE=$(date +"%Y-%m-%d")
          sed -i "s/Última actualización: .*/Última actualización: $DATE/" README.md

      - name: Commit changes
        run: |
          git config user.name "QuestHub Bot"
          git config user.email "bot@questhub.local"

          if [[ -n $(git status --porcelain) ]]; then
            git add README.md
            git commit -m "Auto-update README date"
            git push origin main
          else
            echo "No hay cambios."
          fi
